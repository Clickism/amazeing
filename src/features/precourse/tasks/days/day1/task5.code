var t
var result
# Insert your Code around the 'return' marker
return:

# Guesses a turn for you to take. Given by the exercise.
# 0 -> Turn left
# 1 -> Turn right
guess:
  var zero
  load zero 0
  var direction d
  getdir d
  var b
  eq b d east
  branch b e
  load result 0
  jump return
e:
  load result 1
  jump return
